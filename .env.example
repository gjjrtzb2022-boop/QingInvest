# Supabase public runtime keys (used by browser/client SDK)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase server-side/admin keys (never expose to browser)
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_PROJECT_REF=
SUPABASE_DB_PASSWORD=

# Content sync defaults
CONTENT_SYNC_TARGET=dev
CONTENT_SYNC_MODE=incremental
CONTENT_SYNC_STORAGE_BUCKET=article-assets
CONTENT_SYNC_DATABASE_URL_DEV=postgresql://postgres:postgres@127.0.0.1:54322/postgres
CONTENT_SYNC_DATABASE_URL_PROD=
CONTENT_SYNC_DB_SSL=false

# Optional feature flags
NEXT_PUBLIC_ENABLE_OTP_AUTH=false
NEXT_PUBLIC_ENABLE_PHONE_OTP=false

# Article source (recommended default: github)
ARTICLE_SOURCE=github
ARTICLE_GITHUB_OWNER=
ARTICLE_GITHUB_REPO=
ARTICLE_GITHUB_BRANCH=main
ARTICLE_GITHUB_ARTICLES_PATH=.
ARTICLE_GITHUB_TOKEN=

# Article source publishing
ARTICLE_SOURCE_PUBLISH_REMOTE_URL=
ARTICLE_SOURCE_PUBLISH_BRANCH=main
ARTICLE_SOURCE_PUBLISH_SOURCE=articles-root
