{
  "name": "qingyishanzhang-site",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "clean": "node -e \"const fs=require('fs');['.next','out'].forEach((d)=>{if(fs.existsSync(d)) fs.rmSync(d,{recursive:true,force:true});});\"",
    "sync:covers": "node tools/sync-covers.mjs",
    "sync:content": "node tools/sync-content.mjs",
    "check:env": "node tools/check-env.mjs",
    "check:migrations": "node tools/check-migrations.mjs",
    "verify:rls": "node tools/verify-rls.mjs",
    "verify:content-sync": "node tools/verify-content-sync.mjs",
    "sync:stocks": "node tools/sync-stocks.mjs",
    "dev": "npm run sync:covers && next dev",
    "build": "npm run sync:covers && next build",
    "build:static": "npm run sync:covers && NEXT_OUTPUT_EXPORT=1 next build",
    "start": "next start",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "validate:articles": "node tools/validate-articles.mjs",
    "build:articles": "node tools/build-articles.mjs",
    "build:stock-mentions": "node tools/build-stock-mentions.mjs",
    "export:article-source": "node tools/export-article-source.mjs",
    "publish:article-source": "node tools/publish-article-source.mjs",
    "import:article": "node tools/import-article.mjs",
    "import:raw": "node tools/import-raw-batch.mjs",
    "import:zhihu": "node tools/import-zhihu-records.mjs",
    "rebuild:topic-articles": "node tools/rebuild-topic-articles.mjs",
    "enrich:answer-tags": "node tools/enrich-answer-tags.mjs"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.98.0",
    "gray-matter": "^4.0.3",
    "lightweight-charts": "^5.1.0",
    "next": "^15.2.0",
    "pg": "^8.19.0",
    "pinyin-pro": "^3.28.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "remark": "^15.0.1",
    "remark-gfm": "^4.0.1",
    "remark-html": "^16.0.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.0.12",
    "@types/node": "^22.13.8",
    "@types/pg": "^8.18.0",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "eslint": "^8.57.1",
    "eslint-config-next": "^15.5.12",
    "tailwindcss": "^4.0.12",
    "typescript": "^5.8.2"
  }
}
